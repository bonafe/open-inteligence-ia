# Configurações do Backend Open Intelligence IA

# Provider de Embeddings: 'ollama' (local, grátis) ou 'openai' (nuvem)
EMBEDDING_PROVIDER=ollama

# Modelo Ollama para embeddings (requer: ollama pull nomic-embed-text)
OLLAMA_MODEL=nomic-embed-text

# Chave da API OpenAI (somente necessária se EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=

# Caminho local onde o ChromaDB irá persistir os dados
CHROMA_PATH=./chroma_db
