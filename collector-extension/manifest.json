{
  "manifest_version": 3,
  "name": "Open Intelligence IA - Collector",
  "version": "1.0",
  "description": "Captura passivamente o texto de paginas web para o seu Vector DB local de OSINT.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
